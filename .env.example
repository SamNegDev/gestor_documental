# =========================================
# SPRING PROFILE
# =========================================
SPRING_PROFILES_ACTIVE=prod


# =========================================
# MYSQL
# =========================================
MYSQL_DATABASE=gestor_documental
MYSQL_USER=gestor_app
MYSQL_PASSWORD=CHANGE_ME_APP_DB_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_DB_PASSWORD


# =========================================
# FILE STORAGE
# =========================================
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=25MB
MAX_REQUEST_SIZE=100MB
UPLOAD_ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png


# =========================================
# LOGS
# =========================================
LOG_FILE=/app/logs/gestor-documental.log


# =========================================
# SESSION / COOKIES
# Local Docker with HTTP: false
# VPS production with HTTPS: true
# =========================================
COOKIE_SECURE=true


# =========================================
# INITIAL ADMIN USER
# Only used when no ADMIN exists yet
# =========================================
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD


# =========================================
# OCR / TESSERACT
# Optional. Leave blank so Tesseract uses the path installed by apt.
# Only fill it if `tesseract --list-langs` fails inside the container.
# =========================================
TESSERACT_PATH=tesseract
TESSERACT_DATAPATH=


# =========================================
# EMAIL / MICROSOFT 365
# =========================================
MAIL_ENABLED=false
MAIL_HEALTH_ENABLED=false
MAIL_PROVIDER=smtp
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=usuario@tenant.onmicrosoft.com
MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_FROM=notificaciones@example.com
MAIL_FROM_NAME=Gestoria CN
MAIL_GRAPH_TENANT_ID=
MAIL_GRAPH_CLIENT_ID=
MAIL_GRAPH_CLIENT_SECRET=
MAIL_GRAPH_SENDER=
MAIL_GRAPH_SAVE_TO_SENT_ITEMS=true
APP_PUBLIC_URL=https://app.example.com


# =========================================
# WHATSAPP / META CLOUD API
# =========================================
WHATSAPP_WEBHOOK_VERIFY_TOKEN=CHANGE_ME_WEBHOOK_VERIFY_TOKEN
WHATSAPP_APP_SECRET=


# =========================================
# BACKUPS / MONITORING (VPS)
# =========================================
BACKUP_DIR=/var/backups/gestor_documental
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_AGE_HOURS=36
DISK_USAGE_WARN_PERCENT=85
# Optional rclone destination, for example: onedrive:gestor-documental
BACKUP_RCLONE_REMOTE=
# Optional ping URLs from a monitoring service. They receive a GET request.
MONITOR_SUCCESS_URL=
MONITOR_FAILURE_URL=
